rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isAdmin() {
      return isAuthenticated() && 
        firestore.exists(/databases/(default)/documents/users/$(request.auth.uid)) &&
        firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // avatars: Users can upload their own. Anyone can read.
    match /avatars/{userId}/{fileName} {
      allow read: if true;
      allow write: if isOwner(userId) || isAdmin();
    }

    // payment slips: Private. Only user and Admin can read. Users can upload their own.
    match /payment-slips/{userId}/{fileName} {
      allow read: if isOwner(userId) || isAdmin();
      allow write: if isOwner(userId) || isAdmin();
    }

    // Other public folders: Public read. Admin only write.
    match /players/{allPaths=**} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    match /products/{allPaths=**} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    match /jerseys/{allPaths=**} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    match /matches/{allPaths=**} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    match /league/{allPaths=**} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    match /misc/{allPaths=**} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
